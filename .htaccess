Options -Indexes

RewriteEngine On

# -----------------------------
# CLEAN HTTPS (only if SSL is ready)
# -----------------------------
RewriteCond %{HTTPS} on
RewriteCond %{HTTP_HOST} !^new\.getaroundmobility\.com$ [NC]
RewriteRule ^ https://new.getaroundmobility.com%{REQUEST_URI} [L,R=301]

# -----------------------------
# CLEAN HTTP → HTTPS (safe version)
# -----------------------------
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP_HOST} ^(www\.)?new\.getaroundmobility\.com$ [NC]
RewriteRule ^ https://new.getaroundmobility.com%{REQUEST_URI} [L,R=301]

# -----------------------------
# CLEAN URL ROUTING
# -----------------------------
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.php [QSA,L]